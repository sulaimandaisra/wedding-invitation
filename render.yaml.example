services:
  - type: web
    name: wedding-invitation
    env: node
    plan: free
    buildCommand: cd backend && npm install
    startCommand: cd backend && node server.js
    envVars:
      - key: ADMIN_USERNAME
        value: your_username_here
      - key: ADMIN_PASSWORD
        value: your_password_here
      - key: NODE_ENV
        value: production
    healthCheckPath: /
